# ── Plantilla de variables de entorno ──────────────────────────────────────
# Copiar a `.env` (git-ignored) y rellenar según el ambiente.
#
# CONTRATO: por ambiente, las VITE_APP_SUPABASE_* (navegador) y las SUPABASE_*
# (servidor/bot) DEBEN apuntar al MISMO proyecto Supabase.
#
# Ambientes:
#   • local   → http://127.0.0.1:54321 (supabase start)  [default en dev si se omiten]
#   • leehurg → https://leehurgkpgunksrqjnqm.supabase.co  (staging remoto)
#   • prod    → https://advebubtfjgxwpjxprok.supabase.co  (VPS)

# ── Navegador (build-time) — selecciona el proyecto del frontend ────────────
# Variable PROPIA (Lovable NO la inyecta). Si se omite: dev→local, build prod→prod.
VITE_APP_SUPABASE_URL=
VITE_APP_SUPABASE_PUBLISHABLE_KEY=

# ── Servidor / bot (runtime) — mismo proyecto que las VITE_APP_* de arriba ──
SUPABASE_URL=
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=          # opcional, chat IDs admin separados por coma

# ── IA ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Flags de frontend (build-time; ausente/vacío = OFF) ─────────────────────
# Activar exige reconstruir el bundle (`bun run build`), no basta restart.
VITE_FEATURE_QUICK_REPORT=
VITE_FEATURE_PEOPLE_LINK=
VITE_FEATURE_NAV_MORE=

# Venezuela Se Levanta — plantilla de variables de entorno
#
# Copia este archivo a `.env` y rellena los valores reales del entorno.
# `.env` y `.env.*` están git-ignored (solo `.env.example` se versiona).
# La selección de entorno (dev/staging/prod) vive ENTERAMENTE en `.env`:
# el mismo código corre en todos lados, solo cambia este archivo por máquina.
#
#   - Local/dev    → Supabase staging (leehurgkpgunksrqjnqm) + bot @venezuelalevanta_bot
#   - Producción   → Supabase prod (advebubtfjgxwpjxprok) + bot @VenezuelaSeLevantabot
#
# Tras editar `.env` SIEMPRE reiniciar `bun run dev` (Vite inyecta env al arrancar).

# ── Supabase (server runtime — REQUERIDAS) ───────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_ID=<project-ref>
SUPABASE_PUBLISHABLE_KEY=<anon key>
# Service role: SOLO backend (uploads, broadcast). NUNCA exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# ── Supabase (browser build-time — REQUERIDAS) ───────────────────────────────
# Inyectadas en el bundle por Vite en BUILD time (no runtime). DEBEN apuntar al
# MISMO proyecto que SUPABASE_URL. Si faltan, el frontend cae a
# http://127.0.0.1:54321 (stack local) y todas las llamadas client-side fallan.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon key>

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot token>
# Opcional: chat IDs admin para /broadcast, separados por coma.
TELEGRAM_ADMIN_IDS=

# ── IA ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=<google ai studio key>

# ── Feature flags (opcionales; ausente/vacío = oculto) ───────────────────────
# Activar progresivamente en prod con: pm2 restart venezuela-levanta --update-env
# Valores que cuentan como ON: 1 / true / on / yes
BOT_NEEDS_FLOW=
BOT_HELP_FLOW=
